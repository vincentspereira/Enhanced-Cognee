#cloud-config
# ===========================================================================
# Enhanced Cognee -- production-class host bootstrap (cloud-init)
# ===========================================================================
# Rendered by Terraform (deploy/terraform/{hetzner,digitalocean}). Brings a
# fresh Ubuntu 24.04 box from bare metal to a running Enhanced Cognee stack
# non-interactively -- the automated equivalent of deploy/vps/README.md steps
# 2-9, so the production-hardware SLA re-confirmation is one `terraform apply`.
#
# Secrets: DB passwords are generated ON the box (openssl rand) and written to
# /opt/enhanced-cognee/.env (600). They never transit Terraform state. The only
# value injected from Terraform is the optional ENHANCED_API_KEY (templated);
# the SLA/soak load profiles use dev-open auth and the Postgres FTS path, so no
# LLM key is required to reproduce the capacity numbers.
# ===========================================================================

package_update: true
package_upgrade: true

packages:
  - docker.io
  - docker-compose-v2
  - git
  - python3
  - python3-venv
  - python3-pip
  - ufw
  - fail2ban
  - jq
  - curl
  - openssl

users:
  - name: cognee
    groups: [sudo, docker]
    shell: /bin/bash
    sudo: ['ALL=(ALL) NOPASSWD:ALL']
    ssh_authorized_keys:
      - ${ssh_pubkey}

write_files:
  # Harden SSH: key-only, no root login. Drop-in overrides the distro default.
  - path: /etc/ssh/sshd_config.d/10-enhanced-cognee.conf
    permissions: '0644'
    content: |
      PermitRootLogin no
      PasswordAuthentication no
      ChallengeResponseAuthentication no
      UsePAM yes

  # fail2ban: protect SSH from brute-force (README security-checklist TODO).
  - path: /etc/fail2ban/jail.d/sshd.local
    permissions: '0644'
    content: |
      [sshd]
      enabled = true
      maxretry = 4
      bantime = 1h
      findtime = 10m

  # First-boot provisioning script (kept out of runcmd for readability).
  - path: /opt/bootstrap-enhanced-cognee.sh
    permissions: '0750'
    content: |
      #!/usr/bin/env bash
      set -euo pipefail
      REPO_URL="${repo_url}"
      REPO_REF="${repo_ref}"
      APP_DIR=/opt/enhanced-cognee
      COMPOSE="docker/docker-compose-enhanced-cognee.yml"

      echo "[bootstrap] cloning $REPO_URL@$REPO_REF -> $APP_DIR"
      git clone --branch "$REPO_REF" --depth 1 "$REPO_URL" "$APP_DIR" \
        || git clone "$REPO_URL" "$APP_DIR"
      chown -R cognee:cognee "$APP_DIR"

      # --- Generate secrets on-box (never in Terraform state) ---------------
      PG_PW="$(openssl rand -hex 24)"
      GRAPH_PW="$(openssl rand -hex 24)"
      API_KEY="${enhanced_api_key}"
      if [ -z "$API_KEY" ]; then API_KEY="$(openssl rand -hex 32)"; fi

      cat > "$APP_DIR/.env" <<ENVEOF
      # Generated by cloud-init on first boot. 600 perms; not in git.
      POSTGRES_PASSWORD=$PG_PW
      NEO4J_PASSWORD=$GRAPH_PW
      ARCADEDB_PASSWORD=$GRAPH_PW
      ENHANCED_API_KEY=$API_KEY
      ENHANCED_ENV=production
      ENHANCED_GRAPH_PROVIDER=arcadedb
      # LLM is not exercised by the SLA/soak FTS workload; placeholder is fine.
      LLM_API_KEY=set-me-if-using-cognify
      ENVEOF
      chmod 600 "$APP_DIR/.env"
      chown cognee:cognee "$APP_DIR/.env"
      echo "[bootstrap] wrote .env (ENHANCED_API_KEY saved to /root/enhanced-cognee-api-key.txt)"
      echo "$API_KEY" > /root/enhanced-cognee-api-key.txt
      chmod 600 /root/enhanced-cognee-api-key.txt

      # --- Bring up the stack (DB containers + app) -------------------------
      cd "$APP_DIR"
      echo "[bootstrap] docker compose up -d --build"
      docker compose -f "$COMPOSE" up -d --build

      # --- On-box load-test toolchain (locust + psutil for the soak) --------
      echo "[bootstrap] installing perf-suite venv"
      python3 -m venv "$APP_DIR/.venv-perf"
      "$APP_DIR/.venv-perf/bin/pip" install --quiet --upgrade pip
      "$APP_DIR/.venv-perf/bin/pip" install --quiet locust psutil python-dotenv

      # --- Nightly backups (README step 9) ----------------------------------
      cp "$APP_DIR/deploy/vps/backup.sh" /usr/local/bin/cognee-backup
      chmod +x /usr/local/bin/cognee-backup
      mkdir -p /var/backups/enhanced-cognee
      chown cognee:cognee /var/backups/enhanced-cognee
      echo '30 2 * * * /usr/local/bin/cognee-backup >> /var/log/cognee-backup.log 2>&1' \
        > /etc/cron.d/cognee-backup

      echo "[bootstrap] done. Stack starting; run the perf suite with:"
      echo "  sudo -u cognee $APP_DIR/tests/load/run_perf_suite.sh both"
      touch /opt/.enhanced-cognee-bootstrapped

runcmd:
  # Firewall: SSH + HTTP/S only (load-gen runs on-box, so 8080 stays internal).
  - ufw allow OpenSSH
  - ufw allow 80/tcp
  - ufw allow 443/tcp
  - ufw --force enable
  - systemctl enable --now fail2ban
  - systemctl restart ssh || systemctl restart sshd || true
  - systemctl enable --now docker
  - /opt/bootstrap-enhanced-cognee.sh > /var/log/enhanced-cognee-bootstrap.log 2>&1

final_message: "Enhanced Cognee host bootstrapped in $UPTIME s. See /var/log/enhanced-cognee-bootstrap.log"
