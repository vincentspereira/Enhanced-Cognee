# Enhanced Cognee Environment Configuration
# Enterprise-grade memory stack with Enhanced features
# Copy this file to .env and configure with your actual credentials

# ===========================================
# ENHANCED STACK CONFIGURATION
# ===========================================

# Enhanced Mode (must be "true" for Enhanced stack)
ENHANCED_COGNEE_MODE=true

# Memory Categorization (new feature)
MEMORY_CATEGORIZATION=true
ENHANCED_COGNEE_CONFIG_PATH=.enhanced-cognee-config.json

# Performance Features (new)
PERFORMANCE_MONITORING=false
AUTO_OPTIMIZATION=false
INTELLIGENT_CACHING=true

# ===========================================
# ENHANCED DATABASE CONFIGURATIONS
# ===========================================

# PostgreSQL Configuration (replaces SQLite)
POSTGRES_HOST=localhost
POSTGRES_PORT=25432
POSTGRES_DB=cognee_db
POSTGRES_USER=cognee_user
POSTGRES_PASSWORD=change-me
# Production should use "require" or "verify-full" (not "prefer"/"disable").
POSTGRES_SSL_MODE=prefer
POSTGRES_POOL_SIZE=20
POSTGRES_MAX_OVERFLOW=30

# Qdrant Vector Database (replaces LanceDB)
QDRANT_HOST=localhost
QDRANT_PORT=26333
QDRANT_API_KEY=
QDRANT_COLLECTION_PREFIX=cognee_
QDRANT_TIMEOUT=30
QDRANT_RETRY_COUNT=3
QDRANT_BATCH_SIZE=100

# ===========================================
# GRAPH DATABASE PROVIDER (Phase 2: ArcadeDB default; Apache-2.0)
# ===========================================
# Set to "neo4j" to opt back into legacy Neo4j (GPLv3). Default is
# "arcadedb" which is wire-compatible with the neo4j Python driver
# via ArcadeDB's Bolt plugin. See docs/ARCADEDB_MIGRATION.md.
ENHANCED_GRAPH_PROVIDER=arcadedb

# ArcadeDB Graph Database (new default)
ARCADEDB_URI=bolt://localhost:27687
ARCADEDB_USER=root
ARCADEDB_PASSWORD=change-me
ARCADEDB_DATABASE=cognee_graph

# Neo4j Graph Database (legacy alternative; ENHANCED_GRAPH_PROVIDER=neo4j)
# Same host:port as ArcadeDB so the legacy URL works either way after migration.
NEO4J_URI=bolt://localhost:27687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change-me
NEO4J_DATABASE=neo4j
NEO4J_MAX_CONNECTION_POOL_SIZE=50
NEO4J_CONNECTION_ACQUISITION_TIMEOUT=60

# Redis Cache Layer (new component)
REDIS_HOST=localhost
REDIS_PORT=26379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_CACHE_TTL=3600
REDIS_MAX_CONNECTIONS=100
REDIS_CONNECTION_POOL_SIZE=20

# ===========================================
# LLM AND EMBEDDING CONFIGURATION
# ===========================================

# Primary LLM Configuration
LLM_API_KEY=your_llm_api_key_here
LLM_MODEL=gpt-4
LLM_PROVIDER=openai
LLM_ENDPOINT=https://api.openai.com/v1
LLM_MAX_TOKENS=4000
LLM_TEMPERATURE=0.1

# Fallback LLM Options (Enhanced feature)
LLM_FALLBACK_PROVIDERS=openai
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Embedding Configuration
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIMENSIONS=3072
EMBEDDING_BATCH_SIZE=32
EMBEDDING_CACHE_SIZE=1000

# Alternative: Ollama for local embeddings
# EMBEDDING_PROVIDER=ollama
# EMBEDDING_MODEL=qwen3-embedding:4b-q4_K_M
# EMBEDDING_ENDPOINT=http://localhost:11434/api/embed
# EMBEDDING_DIMENSIONS=2560

# ===========================================
# ENHANCED FEATURES CONFIGURATION
# ===========================================

# Agent Memory Categories (dynamic - see .enhanced-cognee-config.json)
DEFAULT_MEMORY_CATEGORY=general

# Memory Management
MEMORY_RETENTION_DAYS=90
MEMORY_COMPRESSION_THRESHOLD=1000000
MEMORY_AUTO_CLEANUP=false

# Performance Optimization
VECTOR_SEARCH_LIMIT=1000
SIMILARITY_THRESHOLD=0.7
PARALLEL_PROCESSING=true
BATCH_SIZE=50

# Security Configuration
ENV=local
ACCEPT_LOCAL_FILE_PATH=true
ALLOW_HTTP_REQUESTS=true
ALLOW_CYPHER_QUERY=true
TOKENIZERS_PARALLELISM=false

# Enhanced Cognee server hardening knobs
# Deployment environment. Set to "production" to enforce fail-closed behavior
# (server refuses to start without a real ENHANCED_API_KEY and rejects
# built-in dev defaults).
ENHANCED_ENV=development

# API key for the Enhanced Cognee server. REQUIRED in production: when
# ENHANCED_ENV=production the server will refuse to start without it.
ENHANCED_API_KEY=

# Require an X-Tenant-ID header on requests. Set to 1 to enforce tenant
# isolation; default 0 leaves it optional for local development.
ENHANCED_REQUIRE_TENANT=0

# Local dev ONLY -- allows built-in dev passwords; MUST be unset/0 in production.
ENHANCED_ALLOW_INSECURE_DEFAULTS=1

# ===========================================
# MONITORING AND LOGGING
# ===========================================

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=text
LOG_FILE=logs/enhanced-cognee.log
LOG_MAX_SIZE=100MB
LOG_BACKUP_COUNT=5

# Health Check Configuration
HEALTH_CHECK_INTERVAL=30
PERFORMANCE_TRACKING=false

# ===========================================
# MCP SERVER CONFIGURATION
# ===========================================

# MCP Server Settings
# In production, bind to 127.0.0.1 and place behind a reverse proxy
# (e.g. nginx/Caddy) instead of exposing 0.0.0.0 directly.
MCP_SERVER_HOST=0.0.0.0
MCP_SERVER_PORT=8080
MCP_LOG_LEVEL=INFO

# ===========================================
# DEVELOPMENT AND TESTING
# ===========================================

# Development Settings
DEBUG=false
DEVELOPMENT_MODE=false

# Testing Configuration
# TEST_DATABASE_URL=postgresql://test:test@localhost:5433/test_db
# TEST_QDRANT_HOST=localhost
# TEST_REDIS_DB=1
# MOCK_EXTERNAL_APIS=false

# ===========================================
# SECURITY AND AUTHENTICATION (Optional)
# ===========================================

# JWT Configuration (optional, for API server)
# JWT_SECRET_KEY=your_jwt_secret_key_here
# JWT_ALGORITHM=HS256
# JWT_EXPIRATION_HOURS=24

# Rate Limiting (optional)
# RATE_LIMIT_ENABLED=true
# RATE_LIMIT_REQUESTS=100
# RATE_LIMIT_WINDOW=60

# ===========================================
# BACKUP AND RECOVERY (Optional)
# ===========================================

# Backup Configuration
# BACKUP_ENABLED=true
# BACKUP_SCHEDULE="0 2 * * *"  # Daily at 2 AM
# BACKUP_RETENTION_DAYS=30
# BACKUP_STORAGE_PATH=./backups

# ===========================================
# NOTES
# ===========================================
#
# 1. Replace all "your_*_here" placeholders with actual values
# 2. Never commit the actual .env file to version control
# 3. Keep your .env file secure and never share it
# 4. Use strong, unique passwords for all database services
# 5. For production, use environment variables or secret management
# 6. Enhanced ports are used to avoid conflicts:
#    - PostgreSQL: 25432 (not 5432)
#    - Qdrant: 26333 (not 6333)
#    - ArcadeDB Bolt: 27687 (default; was Neo4j Bolt -- drop-in compatible)
#    - ArcadeDB Studio HTTP: 22480
#    - Redis/Valkey: 26379 (not 6379)
